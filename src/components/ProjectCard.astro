---
import { render } from "astro:content";
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"projects">;
  featured?: boolean;
}

const { entry, featured = false } = Astro.props;
const { Content } = await render(entry);
const { title, tagline, stack, status, link, embed, repo } = entry.data;

const isShipped = status === "Shipped";
const statusColor = isShipped ? "text-accent" : "text-text-muted";
---
<article
  class:list={[
    "group relative border border-white/[0.06] bg-secondary/30 transition-colors hover:border-accent/40",
    featured ? "p-6 md:p-8" : "p-6",
  ]}
>
  <div class="flex items-start justify-between gap-4 mb-3">
    <h3 class="text-h2 font-bold tracking-tight text-text-light leading-tight">
      {title}
    </h3>
    <span
      class:list={[
        "shrink-0 font-mono text-xs uppercase tracking-[0.18em] mt-2",
        statusColor,
      ]}
    >
      {status}
    </span>
  </div>

  <p class="text-text-dim text-base md:text-lg leading-relaxed mb-5 max-w-3xl">
    {tagline}
  </p>

  {stack && stack.length > 0 && (
    <ul class="flex flex-wrap gap-2 mb-6">
      {stack.map((s) => (
        <li class="font-mono text-xs text-text-muted border border-text-muted/30 px-2 py-1">
          {s}
        </li>
      ))}
    </ul>
  )}

  {featured && embed && (
    <div class="relative aspect-[4/3] md:aspect-video overflow-hidden border border-text-muted/20 bg-primary mb-6">
      <iframe
        src={embed}
        loading="lazy"
        title={`${title} preview`}
        class="absolute inset-0 w-full h-full"
        sandbox="allow-scripts"
      ></iframe>
    </div>
  )}

  {featured && (
    <div class="text-text-dim leading-relaxed text-base max-w-3xl mb-6">
      <Content />
    </div>
  )}

  <div class="flex flex-wrap gap-4 font-mono text-sm">
    {link && (
      <a
        href={link}
        target="_blank"
        rel="noopener noreferrer"
        class="text-accent hover:text-accent-2 transition-colors"
      >
        Open live ↗
      </a>
    )}
    {embed && !link && (
      <a
        href={embed}
        target="_blank"
        rel="noopener noreferrer"
        class="text-accent hover:text-accent-2 transition-colors"
      >
        Open in new tab ↗
      </a>
    )}
    {repo && (
      <a
        href={repo}
        target="_blank"
        rel="noopener noreferrer"
        class="text-text-muted hover:text-text-light transition-colors"
      >
        Source ↗
      </a>
    )}
  </div>
</article>
