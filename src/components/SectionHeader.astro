---
interface Props {
  number: string;
  title: string;
  subtitle?: string;
  liveDot?: boolean;
}

const { number, title, subtitle, liveDot = false } = Astro.props;
---
<header class="mb-10 md:mb-14">
  <div class="flex items-center gap-4 mb-3">
    <span class="font-mono text-sm text-accent tracking-widest">{number}</span>
    {subtitle && (
      <span class="font-mono text-xs uppercase tracking-[0.2em] text-text-muted">
        {subtitle}
      </span>
    )}
  </div>
  <div class="flex items-center gap-3">
    <h2 class="text-h2 font-bold tracking-tight text-text-light">{title}</h2>
    {liveDot && <span class="live-dot" aria-label="Recently updated"></span>}
  </div>
  <div class="mt-4 h-px w-12 bg-accent"></div>
</header>
