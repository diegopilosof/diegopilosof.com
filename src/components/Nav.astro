---
import { getCollection } from "astro:content";

const writingEntries = await getCollection("writing");
const hasWriting = writingEntries.length > 0;

const links = [
  { href: "#about", label: "About", desktop: true, mobile: false },
  { href: "#now", label: "Now", desktop: true, mobile: true },
  { href: "#projects", label: "Projects", desktop: true, mobile: true },
  { href: "#writing", label: "Writing", desktop: hasWriting, mobile: false },
  { href: "#experience", label: "Experience", desktop: true, mobile: false },
  { href: "#contact", label: "Contact", desktop: true, mobile: true },
];

const desktopLinks = links.filter((l) => l.desktop);
const mobileLinks = links.filter((l) => l.mobile);
---
<nav class="fixed top-0 inset-x-0 z-40 backdrop-blur-md bg-primary/70 border-b border-white/[0.06]" data-no-print>
  <div class="max-w-6xl mx-auto px-6 md:px-12 h-14 flex items-center justify-between">
    <a href="#top" class="flex items-center gap-2 group" aria-label="Back to top">
      <span class="font-mono text-sm font-semibold tracking-wider">
        <span class="text-accent">DP</span><span class="text-text-muted group-hover:text-text-dim transition-colors">.</span>
      </span>
    </a>

    <ul class="flex md:hidden items-center gap-4 text-xs font-mono">
      {mobileLinks.map(({ href, label }) => (
        <li>
          <a href={href} class="text-text-muted hover:text-text-light transition-colors">
            {label}
          </a>
        </li>
      ))}
    </ul>

    <ul class="hidden md:flex items-center gap-7 text-sm font-mono">
      {desktopLinks.map(({ href, label }) => (
        <li>
          <a href={href} class="text-text-muted hover:text-text-light transition-colors">
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>
