---
const year = new Date().getFullYear();
---
<footer class="px-6 md:px-12 lg:px-24 py-10 border-t border-white/[0.06]" data-no-print>
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row gap-3 items-start md:items-center justify-between font-mono text-xs text-text-muted">
    <p>
      Diego Pilosof <span class="text-text-muted/60">·</span> {year}
    </p>
    <div class="flex items-center gap-5">
      <a
        href="https://www.linkedin.com/in/diegopilosof"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-accent transition-colors"
      >
        LinkedIn ↗
      </a>
      <a href="#top" class="hover:text-accent transition-colors">
        Back to top ↑
      </a>
    </div>
  </div>
</footer>
